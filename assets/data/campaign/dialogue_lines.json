[
  {
    "id": "narrator_ch0_start",
    "opponent_id": "narrator",
    "timing": null,
    "encounter": null,
    "result_history": null,
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "",
    "speakerKey": "speaker.narrator",
    "text": "The hall at Tara was quiet after, and it is I that made it quiet. Murchadh mac Fáelán never raised his voice — it was the board that said what he wished said, and the board said it plain.",
    "textKey": "dialogue.narrator_ch0_start"
  },
  {
    "id": "narrator_ch0_post_scripted",
    "opponent_id": "narrator",
    "timing": null,
    "encounter": null,
    "result_history": null,
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "",
    "speakerKey": "speaker.narrator",
    "text": "I am after walking out of Tara with nothing but the clothes on my back and the game still turning in my head. There are roads west — there are always roads west — and people who have not yet heard my name said wrong.",
    "textKey": "dialogue.narrator_ch0_post_scripted"
  },
  {
    "id": "narrator_ch1_start",
    "opponent_id": "narrator",
    "timing": null,
    "encounter": null,
    "result_history": null,
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "",
    "speakerKey": "speaker.narrator",
    "text": "Connacht. The Atlantic comes in hard off the headlands and everything here has the smell of salt and old rain. These people have their own games, their own grievances. It is nobody I am here, and that is the right place to start from.",
    "textKey": "dialogue.narrator_ch1_start"
  },
  {
    "id": "narrator_ch1_end",
    "opponent_id": "narrator",
    "timing": null,
    "encounter": null,
    "result_history": null,
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "",
    "speakerKey": "speaker.narrator",
    "text": "Fiachra let me go without a word, and it is a long while I felt his eyes at my back. The road east is longer than the one I came by. Murchadh is at the end of it, and he does not know yet that I am walking.",
    "textKey": "dialogue.narrator_ch1_end"
  },
  {
    "id": "murchadh_pre_scripted",
    "opponent_id": "murchadh",
    "timing": "pre_match",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": false,
    "is_final_boss": false,
    "match_type": "scripted",
    "speaker": "Murchadh mac Fáelán",
    "speakerKey": "speaker.murchadh",
    "text": "It is your name I have heard. I had expected something more of it.",
    "textKey": "dialogue.murchadh_pre_scripted"
  },
  {
    "id": "murchadh_post_loss_scripted",
    "opponent_id": "murchadh",
    "timing": "post_loss",
    "encounter": "first",
    "result_history": null,
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": false,
    "is_final_boss": false,
    "match_type": "scripted",
    "speaker": "Murchadh mac Fáelán",
    "speakerKey": "speaker.murchadh",
    "text": "Go west. There might be people out along those roads who would not yet know to refuse you.",
    "textKey": "dialogue.murchadh_post_loss_scripted"
  },
  {
    "id": "seanan_pre_first",
    "opponent_id": "seanan",
    "timing": "pre_match",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Séanán na Farraige",
    "speakerKey": "speaker.seanan",
    "text": "Sit, sit — it was the net I was meaning to mend but sure it will wait. You have the look of a person who has been walking.",
    "textKey": "dialogue.seanan_pre_first"
  },
  {
    "id": "seanan_post_win_first",
    "opponent_id": "seanan",
    "timing": "post_win",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Séanán na Farraige",
    "speakerKey": "speaker.seanan",
    "text": "Ha. Well now. The fish will not mock me for it, I suppose. It is someone who has lost before that you play like — and did not forget the losing.",
    "textKey": "dialogue.seanan_post_win_first"
  },
  {
    "id": "seanan_post_loss_first",
    "opponent_id": "seanan",
    "timing": "post_loss",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Séanán na Farraige",
    "speakerKey": "speaker.seanan",
    "text": "There it is. I do not always see the whole board but sometimes the board will show me a thing anyway. Stay and eat, so, if you have no place to be.",
    "textKey": "dialogue.seanan_post_loss_first"
  },
  {
    "id": "seanan_pre_retry",
    "opponent_id": "seanan",
    "timing": "pre_match",
    "encounter": "second",
    "result_history": "lost_to_them",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Séanán na Farraige",
    "speakerKey": "speaker.seanan",
    "text": "Back already. I thought you might be, right enough. Here — the board is where you left it.",
    "textKey": "dialogue.seanan_pre_retry"
  },
  {
    "id": "brigid_pre_first",
    "opponent_id": "brigid",
    "timing": "pre_match",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Brigid na Scailpe",
    "speakerKey": "speaker.brigid",
    "text": "It is not in haste I play, and it is not in company I do not trust. Sit with me a while first. Then we will see what there is to see.",
    "textKey": "dialogue.brigid_pre_first"
  },
  {
    "id": "brigid_post_win_first",
    "opponent_id": "brigid",
    "timing": "post_win",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Brigid na Scailpe",
    "speakerKey": "speaker.brigid",
    "text": "It is as though you have been the King yourself that you protect him. That is not a thing you would find commonly.",
    "textKey": "dialogue.brigid_post_win_first"
  },
  {
    "id": "brigid_post_loss_first",
    "opponent_id": "brigid",
    "timing": "post_loss",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Brigid na Scailpe",
    "speakerKey": "speaker.brigid",
    "text": "You opened too early. Patience is not the absence of movement — it is knowing which movement to withhold.",
    "textKey": "dialogue.brigid_post_loss_first"
  },
  {
    "id": "brigid_pre_retry",
    "opponent_id": "brigid",
    "timing": "pre_match",
    "encounter": "second",
    "result_history": "lost_to_them",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Brigid na Scailpe",
    "speakerKey": "speaker.brigid",
    "text": "You have been thinking on it since. I can see that in you. Good — it is thinking that is most of the game.",
    "textKey": "dialogue.brigid_pre_retry"
  },
  {
    "id": "tadhg_pre_first",
    "opponent_id": "tadhg",
    "timing": "pre_match",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Tadhg an Ósta",
    "speakerKey": "speaker.tadhg",
    "text": "Three men I have beaten today already and the night still young on us. Set the board — I have not the whole evening to be giving you.",
    "textKey": "dialogue.tadhg_pre_first"
  },
  {
    "id": "tadhg_post_win_first",
    "opponent_id": "tadhg",
    "timing": "post_win",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Tadhg an Ósta",
    "speakerKey": "speaker.tadhg",
    "text": "Right, right. Fair enough for you. Was it Séanán sent you? He has the look of a man that does his teaching quietly.",
    "textKey": "dialogue.tadhg_post_win_first"
  },
  {
    "id": "tadhg_post_loss_first",
    "opponent_id": "tadhg",
    "timing": "post_loss",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Tadhg an Ósta",
    "speakerKey": "speaker.tadhg",
    "text": "You held too long. A man that will not press his advantage is a man that is asking to lose. Come back when you have the stomach in you for it.",
    "textKey": "dialogue.tadhg_post_loss_first"
  },
  {
    "id": "tadhg_pre_retry",
    "opponent_id": "tadhg",
    "timing": "pre_match",
    "encounter": "second",
    "result_history": "lost_to_them",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Tadhg an Ósta",
    "speakerKey": "speaker.tadhg",
    "text": "Again. Fine so. It is not easy I will be making it this time.",
    "textKey": "dialogue.tadhg_pre_retry"
  },
  {
    "id": "fiachra_pre_first",
    "opponent_id": "fiachra",
    "timing": "pre_match",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": true,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Fiachra an Fhánaí",
    "speakerKey": "speaker.fiachra",
    "text": "Three different things I heard about you from three different people, and not one of them agreed. Sit — it is which one is the truth I want to see.",
    "textKey": "dialogue.fiachra_pre_first"
  },
  {
    "id": "fiachra_post_win_first",
    "opponent_id": "fiachra",
    "timing": "post_win",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": true,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Fiachra an Fhánaí",
    "speakerKey": "speaker.fiachra",
    "text": "There is someone east of here who has not seen that yet. I wonder will you be there before the word of it travels ahead of you.",
    "textKey": "dialogue.fiachra_post_win_first"
  },
  {
    "id": "fiachra_post_loss_first",
    "opponent_id": "fiachra",
    "timing": "post_loss",
    "encounter": "first",
    "result_history": "no_prior",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": true,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Fiachra an Fhánaí",
    "speakerKey": "speaker.fiachra",
    "text": "You read the board well enough. But it is the player you are not reading, and that is where the gap is.",
    "textKey": "dialogue.fiachra_post_loss_first"
  },
  {
    "id": "fiachra_pre_retry",
    "opponent_id": "fiachra",
    "timing": "pre_match",
    "encounter": "second",
    "result_history": "lost_to_them",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": true,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Fiachra an Fhánaí",
    "speakerKey": "speaker.fiachra",
    "text": "You came back. That is the first thing I was needing to know about you.",
    "textKey": "dialogue.fiachra_pre_retry"
  },
  {
    "id": "seanan_post_win_retry",
    "opponent_id": "seanan",
    "timing": "post_win",
    "encounter": null,
    "result_history": "lost_to_them",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Séanán na Farraige",
    "speakerKey": "speaker.seanan",
    "text": "You came back quieter than you went, and you played quieter too. That is the sea's way of teaching — not with words, not with any fuss at all.",
    "textKey": "dialogue.seanan_post_win_retry"
  },
  {
    "id": "brigid_post_win_retry",
    "opponent_id": "brigid",
    "timing": "post_win",
    "encounter": null,
    "result_history": "lost_to_them",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Brigid na Scailpe",
    "speakerKey": "speaker.brigid",
    "text": "You held the thing you learned and did not let the losing spoil it. That is the harder discipline, and it is you that had it in you all along.",
    "textKey": "dialogue.brigid_post_win_retry"
  },
  {
    "id": "tadhg_post_win_retry",
    "opponent_id": "tadhg",
    "timing": "post_win",
    "encounter": null,
    "result_history": "lost_to_them",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Tadhg an Ósta",
    "speakerKey": "speaker.tadhg",
    "text": "All right, all right — you came back and you came back with something, I will give you that much and not a word more than that.",
    "textKey": "dialogue.tadhg_post_win_retry"
  },
  {
    "id": "fiachra_post_win_retry",
    "opponent_id": "fiachra",
    "timing": "post_win",
    "encounter": null,
    "result_history": "lost_to_them",
    "feud_state": null,
    "reputation_tier": null,
    "is_chapter_boss": true,
    "is_final_boss": null,
    "match_type": "standard",
    "speaker": "Fiachra an Fhánaí",
    "speakerKey": "speaker.fiachra",
    "text": "The second thing — you came back and you won it. The road east is yours now.",
    "textKey": "dialogue.fiachra_post_win_retry"
  },

  {
    "id": "seanan_feud_pre",
    "opponent_id": "seanan",
    "timing": "pre_match",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Séanán na Farraige",
    "speakerKey": "speaker.seanan",
    "text": "It was not yourself I was expecting to see here again, not after the way that went. Sit then — but easy I will not be going.",
    "textKey": "dialogue.seanan_feud_pre"
  },
  {
    "id": "seanan_feud_post_win",
    "opponent_id": "seanan",
    "timing": "post_win",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Séanán na Farraige",
    "speakerKey": "speaker.seanan",
    "text": "There now. That is a thing itself. What was before — I will not be holding that against what just happened. The board has a memory of its own.",
    "textKey": "dialogue.seanan_feud_post_win"
  },
  {
    "id": "seanan_feud_post_loss",
    "opponent_id": "seanan",
    "timing": "post_loss",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Séanán na Farraige",
    "speakerKey": "speaker.seanan",
    "text": "Again. I do not know what it is you are trying to prove, but the board keeps telling you it is not proved yet.",
    "textKey": "dialogue.seanan_feud_post_loss"
  },
  {
    "id": "seanan_nemesis_pre",
    "opponent_id": "seanan",
    "timing": "pre_match",
    "encounter": null,
    "result_history": null,
    "feud_state": "nemesis",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Séanán na Farraige",
    "speakerKey": "speaker.seanan",
    "text": "Nothing have I said to anyone about this, and I will not say it. But you keep coming back, and I keep on winning, and that much is between ourselves.",
    "textKey": "dialogue.seanan_nemesis_pre"
  },
  {
    "id": "seanan_nemesis_post_win",
    "opponent_id": "seanan",
    "timing": "post_win",
    "encounter": null,
    "result_history": null,
    "feud_state": "nemesis",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Séanán na Farraige",
    "speakerKey": "speaker.seanan",
    "text": "Well. There it is now. It is not in the sea's nature to stay angry — that was never the way of it. Go on, so.",
    "textKey": "dialogue.seanan_nemesis_post_win"
  },

  {
    "id": "brigid_feud_pre",
    "opponent_id": "brigid",
    "timing": "pre_match",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Brigid na Scailpe",
    "speakerKey": "speaker.brigid",
    "text": "It is time I gave you, and it is the game straight I gave you. What you took from that was not what was offered. Come — we will see now if you have put it right.",
    "textKey": "dialogue.brigid_feud_pre"
  },
  {
    "id": "brigid_feud_post_win",
    "opponent_id": "brigid",
    "timing": "post_win",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Brigid na Scailpe",
    "speakerKey": "speaker.brigid",
    "text": "You found the discipline. That is what I was waiting for — not the win, the discipline behind it. We are done with this.",
    "textKey": "dialogue.brigid_feud_post_win"
  },
  {
    "id": "brigid_feud_post_loss",
    "opponent_id": "brigid",
    "timing": "post_loss",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Brigid na Scailpe",
    "speakerKey": "speaker.brigid",
    "text": "It is the same gap, only showing in a different place. You have not found the root of it yet. I have nothing more to say on it.",
    "textKey": "dialogue.brigid_feud_post_loss"
  },
  {
    "id": "brigid_nemesis_pre",
    "opponent_id": "brigid",
    "timing": "pre_match",
    "encounter": null,
    "result_history": null,
    "feud_state": "nemesis",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Brigid na Scailpe",
    "speakerKey": "speaker.brigid",
    "text": "It is not with heat I hold things. It is with stillness. A long time you have had now to feel that stillness, and it has not moved you yet. Sit.",
    "textKey": "dialogue.brigid_nemesis_pre"
  },
  {
    "id": "brigid_nemesis_post_win",
    "opponent_id": "brigid",
    "timing": "post_win",
    "encounter": null,
    "result_history": null,
    "feud_state": "nemesis",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Brigid na Scailpe",
    "speakerKey": "speaker.brigid",
    "text": "It was the time of it I misjudged — how long it would take. That error is mine, not yours. You have the thing now. Keep it.",
    "textKey": "dialogue.brigid_nemesis_post_win"
  },

  {
    "id": "tadhg_feud_pre",
    "opponent_id": "tadhg",
    "timing": "pre_match",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Tadhg an Ósta",
    "speakerKey": "speaker.tadhg",
    "text": "I told everyone in this house you would come back and lose again. Do not be making me wrong in front of them.",
    "textKey": "dialogue.tadhg_feud_pre"
  },
  {
    "id": "tadhg_feud_post_win",
    "opponent_id": "tadhg",
    "timing": "post_win",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Tadhg an Ósta",
    "speakerKey": "speaker.tadhg",
    "text": "The once. In my hall. I will not be pretending that did not happen. But do not think it means more than the one time it was.",
    "textKey": "dialogue.tadhg_feud_post_win"
  },
  {
    "id": "tadhg_feud_post_loss",
    "opponent_id": "tadhg",
    "timing": "post_loss",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Tadhg an Ósta",
    "speakerKey": "speaker.tadhg",
    "text": "Twice now. Walk away and do not come back to me until you have something I have not already beaten.",
    "textKey": "dialogue.tadhg_feud_post_loss"
  },
  {
    "id": "tadhg_nemesis_pre",
    "opponent_id": "tadhg",
    "timing": "pre_match",
    "encounter": null,
    "result_history": null,
    "feud_state": "nemesis",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Tadhg an Ósta",
    "speakerKey": "speaker.tadhg",
    "text": "It is beaten you I have enough times that your name in this hall is a story people tell for a laugh. Prove it wrong or do not sit down at all.",
    "textKey": "dialogue.tadhg_nemesis_pre"
  },
  {
    "id": "tadhg_nemesis_post_win",
    "opponent_id": "tadhg",
    "timing": "post_win",
    "encounter": null,
    "result_history": null,
    "feud_state": "nemesis",
    "reputation_tier": null,
    "is_chapter_boss": null,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Tadhg an Ósta",
    "speakerKey": "speaker.tadhg",
    "text": "You won. In my hall. In front of my people. I will not be pretending it did not happen. That is the full of what I have for you.",
    "textKey": "dialogue.tadhg_nemesis_post_win"
  },

  {
    "id": "fiachra_feud_pre",
    "opponent_id": "fiachra",
    "timing": "pre_match",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": true,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Fiachra an Fhánaí",
    "speakerKey": "speaker.fiachra",
    "text": "It is something on your face you came back with that was not there before. It is not the board I think you are angry at. Sit — let us find out what it is.",
    "textKey": "dialogue.fiachra_feud_pre"
  },
  {
    "id": "fiachra_feud_post_win",
    "opponent_id": "fiachra",
    "timing": "post_win",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": true,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Fiachra an Fhánaí",
    "speakerKey": "speaker.fiachra",
    "text": "It was not the move I was watching for — it was what came before the move. You found something in yourself. The rest of this is finished now.",
    "textKey": "dialogue.fiachra_feud_post_win"
  },
  {
    "id": "fiachra_feud_post_loss",
    "opponent_id": "fiachra",
    "timing": "post_loss",
    "encounter": null,
    "result_history": null,
    "feud_state": "in_feud",
    "reputation_tier": null,
    "is_chapter_boss": true,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Fiachra an Fhánaí",
    "speakerKey": "speaker.fiachra",
    "text": "It is something you are carrying into the game that has no business being there. Until you set it down, you will keep losing it for reasons that have nothing to do with the board.",
    "textKey": "dialogue.fiachra_feud_post_loss"
  },
  {
    "id": "fiachra_nemesis_pre",
    "opponent_id": "fiachra",
    "timing": "pre_match",
    "encounter": null,
    "result_history": null,
    "feud_state": "nemesis",
    "reputation_tier": null,
    "is_chapter_boss": true,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Fiachra an Fhánaí",
    "speakerKey": "speaker.fiachra",
    "text": "Nothing have I told to anyone of what I think is happening with you. There is time yet to settle it on the board. It is the last time I will be offering that.",
    "textKey": "dialogue.fiachra_nemesis_pre"
  },
  {
    "id": "fiachra_nemesis_post_win",
    "opponent_id": "fiachra",
    "timing": "post_win",
    "encounter": null,
    "result_history": null,
    "feud_state": "nemesis",
    "reputation_tier": null,
    "is_chapter_boss": true,
    "is_final_boss": null,
    "match_type": null,
    "speaker": "Fiachra an Fhánaí",
    "speakerKey": "speaker.fiachra",
    "text": "I wondered for a while would you get here. Then I stopped wondering and I started waiting. The road east is clearer now — you have settled the thing that was clouding it.",
    "textKey": "dialogue.fiachra_nemesis_post_win"
  }
]
