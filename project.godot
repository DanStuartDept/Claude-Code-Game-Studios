; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Fidchell"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/main_scene="res://scenes/menu/MainMenu.tscn"

[autoload]

SceneManager="*res://src/core/scene_manager.gd"
BoardRules="*res://src/core/board_rules.gd"
AISystem="*res://src/core/ai_system.gd"
CampaignSystem="*res://src/core/campaign_system.gd"
ReputationSystem="*res://src/core/reputation_system.gd"
DialogueSystem="*res://src/core/dialogue_system.gd"
SaveSystem="*res://src/core/save_system.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdUnit4/plugin.cfg")

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"
window/handheld/orientation=1

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
